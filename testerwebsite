<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Website Absensi Pekerja</title>
  <script>
    // Load saved theme early to avoid FOUC
    const savedTheme = localStorage.getItem("theme") || "day";
    document.documentElement.dataset.theme = savedTheme;
  </script>
  <style>
    :root {
      color-scheme: light;
      --bg: #f6f1e8;
      --bg-pattern: rgba(35, 83, 73, 0.08);
      --surface: rgba(255, 252, 245, 0.92);
      --surface-solid: #fffaf0;
      --surface-soft: #f2eadc;
      --line: rgba(58, 70, 63, 0.17);
      --text: #25322f;
      --muted: #69746f;
      --brand: #1f6f5f;
      --brand-dark: #155348;
      --accent: #b98546;
      --danger: #b34a2e;
      --shadow: 0 18px 50px rgba(37, 50, 47, 0.13);
      --header-text: #fffaf0;
      --hero-overlay: linear-gradient(135deg, rgba(20, 63, 55, 0.95), rgba(34, 81, 69, 0.84));
    }

    @page {
      size: A4 landscape;
      margin: 12mm;
    }

    [data-theme="night"] {
      color-scheme: dark;
      --bg: #111816;
      --bg-pattern: rgba(192, 145, 86, 0.1);
      --surface: rgba(25, 34, 31, 0.9);
      --surface-solid: #19221f;
      --surface-soft: #202c28;
      --line: rgba(224, 210, 184, 0.16);
      --text: #f4efe4;
      --muted: #b9c0b5;
      --brand: #5bc4ad;
      --brand-dark: #3aa58f;
      --accent: #d5a668;
      --danger: #df6f4b;
      --shadow: 0 22px 60px rgba(0, 0, 0, 0.34);
      --header-text: #fffaf0;
      --hero-overlay: linear-gradient(135deg, rgba(10, 18, 16, 0.96), rgba(28, 52, 46, 0.88));
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 20% 0%, var(--bg-pattern), transparent 28%),
        radial-gradient(circle at 90% 15%, rgba(185, 133, 70, 0.14), transparent 24%),
        linear-gradient(180deg, var(--bg), var(--surface-soft));
      transition: background 0.25s ease, color 0.25s ease;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.5;
      background-image:
        linear-gradient(30deg, transparent 48%, rgba(127, 104, 72, 0.08) 49%, rgba(127, 104, 72, 0.08) 51%, transparent 52%),
        linear-gradient(150deg, transparent 48%, rgba(31, 111, 95, 0.07) 49%, rgba(31, 111, 95, 0.07) 51%, transparent 52%);
      background-size: 42px 42px;
    }

    header {
      position: relative;
      overflow: hidden;
      padding: 28px 24px 34px;
      color: var(--header-text);
      background: var(--hero-overlay), linear-gradient(90deg, rgba(0,0,0,0.05), rgba(255,255,255,0.02));
      background-size: cover;
      box-shadow: var(--shadow);
    }

    .hero-inner { position: relative; z-index: 1; width: min(1180px, calc(100% - 8px)); margin: 0 auto; display: flex; gap: 18px; justify-content: space-between; align-items: center; }
    .brand-row { display: flex; gap: 16px; align-items: center; }

    .brand-mark { width: 62px; height: 62px; display: grid; place-items: center; border: 1px solid rgba(255, 250, 240, 0.26); border-radius: 8px; background: rgba(255, 250, 240, 0.12); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.07); }
    .brand-mark::before { content: ""; width: 34px; height: 24px; border: 3px solid #f3d6a6; border-top: 0; border-radius: 0 0 13px 13px; }

    header h1 { margin: 0 0 7px; font-size: clamp(27px, 4vw, 44px); line-height: 1; }
    header p { margin: 0; max-width: 680px; color: rgba(255,250,240,0.9); font-size: 15px; }

    .theme-toggle { min-width: 126px; border: 1px solid rgba(255,250,240,0.26); color: var(--header-text); background: rgba(255,250,240,0.12); backdrop-filter: blur(10px); padding: 10px; border-radius: 6px; }

    main { position: relative; z-index: 1; width: min(1180px, calc(100% - 32px)); margin: 24px auto 36px; display: grid; gap: 18px; }
    section { padding: 20px; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; box-shadow: var(--shadow); backdrop-filter: blur(16px); }
    h2 { margin: 0 0 14px; font-size: 20px; color: var(--text); }

    form { display: grid; grid-template-columns: repeat(4, minmax(150px, 1fr)); gap: 12px; align-items: end; }
    label { display: grid; gap: 7px; font-size: 13px; font-weight: 700; color: var(--muted); }
    input, select { width: 100%; padding: 11px 12px; border: 1px solid var(--line); border-radius: 6px; font: inherit; font-size: 16px; color: var(--text); background: var(--surface-solid); }
    input:focus, select:focus { outline: 3px solid rgba(31,111,95,0.16); border-color: var(--brand); }

    button { min-height: 42px; padding: 10px 14px; border: 0; border-radius: 6px; font-weight: 800; color: #fffaf0; background: linear-gradient(135deg, var(--brand), var(--brand-dark)); cursor: pointer; box-shadow: 0 8px 18px rgba(21,83,72,0.18); }
    button:hover { filter: brightness(1.04); transform: translateY(-1px); }
    button.secondary { color: var(--brand); background: color-mix(in srgb, var(--brand) 12%, var(--surface-solid)); box-shadow: none; }
    button.danger { color: white; background: linear-gradient(135deg, var(--danger), #8f3322); }

    .button-group { display: flex; flex-wrap: wrap; gap: 8px; align-items: end; }
    .button-group button { flex: 1 1 150px; }
    .slip-picker { display: grid; gap: 8px; }
    .toolbar { display: flex; flex-wrap: wrap; gap: 10px; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .toolbar-actions { display: flex; flex-wrap: wrap; gap: 10px; }
    .is-hidden { display: none; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 8px; }
    table { width: 100%; border-collapse: collapse; min-width: 720px; background: var(--surface-solid); }
    th, td { padding: 12px 11px; border-bottom: 1px solid var(--line); text-align: left; vertical-align: top; font-size: 14px; }
    th { color: var(--muted); background: color-mix(in srgb, var(--accent) 13%, var(--surface-solid)); font-size: 12px; text-transform: uppercase; }
    tr:last-child td { border-bottom: 0; }
    .empty { padding: 22px; border: 1px dashed var(--line); border-radius: 8px; color: var(--muted); text-align: center; background: var(--surface-soft); }

    .summary { display: grid; grid-template-columns: repeat(4, minmax(140px, 1fr)); gap: 12px; margin-bottom: 14px; }
    .summary div { padding: 15px; border: 1px solid var(--line); border-radius: 8px; background: var(--surface-solid); }
    .summary span { display: block; margin-bottom: 7px; color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
    .summary strong { font-size: 18px; color: var(--text); }

    .actions { display: flex; flex-wrap: wrap; gap: 8px; }
    .actions button { min-height: 34px; padding: 8px 10px; font-size: 13px; }

    .mass-card { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--line); }
    .mass-form { grid-template-columns: repeat(3, minmax(150px, 1fr)); }
    .mass-actions { display: flex; flex-wrap: wrap; gap: 8px; margin: 12px 0; }
    .mass-list { display: grid; gap: 8px; max-height: 260px; overflow: auto; padding: 10px; border: 1px solid var(--line); border-radius: 8px; background: var(--surface-solid); }
    .mass-worker { display: grid; grid-template-columns: 1fr auto; gap: 10px; align-items: center; padding: 10px; border: 1px solid var(--line); border-radius: 8px; background: var(--surface-soft); }
    .mass-worker label { display: flex; gap: 10px; align-items: center; color: var(--text); font-size: 14px; }
    .mass-worker input { width: 18px; height: 18px; accent-color: var(--brand); }
    .mass-worker small { display: block; margin-top: 3px; color: var(--muted); font-weight: 600; }

    @media (max-width: 860px) {
      .hero-inner, .brand-row { align-items: flex-start; }
      .hero-inner { flex-direction: column; }
      form, .grid-2, .mass-form, .summary { grid-template-columns: 1fr; }
      .mass-worker { grid-template-columns: 1fr; }
    }

    @media (max-width: 560px) {
      body::before { opacity: 0.26; background-size: 34px 34px; }
      header { padding: 18px 14px 22px; }
      .hero-inner { width: 100%; gap: 14px; }
      .brand-row { gap: 12px; }
      .brand-mark { width: 48px; height: 48px; flex: 0 0 48px; }
      header h1 { font-size: 25px; line-height: 1.08; }
      header p { font-size: 13px; line-height: 1.45; }
      .theme-toggle { width: 100%; }
      main { width: calc(100% - 20px); margin: 14px auto 24px; gap: 12px; }
      section { padding: 14px; box-shadow: 0 10px 28px rgba(37,50,47,0.1); }
      h2 { font-size: 18px; margin-bottom: 12px; }
      form { gap: 10px; }
      button { width: 100%; min-height: 46px; padding: 11px 12px; font-size: 14px; }
      .toolbar { align-items: stretch; }
      .toolbar h2 { width: 100%; margin-bottom: 0; }
      .toolbar-actions, .button-group, .mass-actions, .actions { width: 100%; display: grid; grid-template-columns: 1fr; }
      .table-wrap { margin-inline: -4px; border-radius: 6px; -webkit-overflow-scrolling: touch; }
      table { min-width: 620px; }
      th, td { padding: 10px 9px; font-size: 13px; white-space: nowrap; }
      td:first-child, th:first-child { position: sticky; left: 0; z-index: 1; background: var(--surface-solid); }
      th:first-child { background: color-mix(in srgb, var(--accent) 13%, var(--surface-solid)); }
      .summary { gap: 8px; margin-bottom: 10px; }
      .summary div { padding: 12px; }
      .summary strong { font-size: 16px; overflow-wrap: anywhere; }
      .mass-list { max-height: 340px; padding: 8px; }
      .mass-worker { padding: 10px; }
      .mass-worker label { align-items: flex-start; line-height: 1.35; }
      .mass-worker input { margin-top: 2px; flex: 0 0 18px; }
      .empty { padding: 16px; font-size: 14px; }
    }

    /* Print styles for salary slip */
    @media print {
      body * { visibility: hidden; }
      #printArea, #printArea * { visibility: visible; }
      #printArea { position: absolute; left: 0; top: 0; width: 100%; }
    }
  </style>
</head>
<body>
  <header>
    <div class="hero-inner">
      <div class="brand-row">
        <div class="brand-mark" aria-hidden="true"></div>
        <div>
          <h1>Absensi Otomatis</h1>
          <p>Project sederhana untuk mencatat absensi dan menghitung slip gaji. Jika ada masukan, hubungi: <a href="mailto:hubungi@contoh.com">hubungi@contoh.com</a></p>
        </div>
      </div>
      <div>
        <button class="theme-toggle" type="button" id="themeToggle" aria-pressed="false">Mode Malam</button>
      </div>
    </div>
  </header>

  <main>
    <section aria-labelledby="add-worker-title">
      <h2 id="add-worker-title">Tambahkan Pekerja</h2>
      <form id="workerForm">
        <label>
          Nama Pekerja
          <input id="workerName" type="text" placeholder="Contoh: Budi" required aria-required="true">
        </label>
        <label>
          Jabatan
          <input id="workerRole" type="text" placeholder="Contoh: Operator" required aria-required="true">
        </label>
        <label>
          Gaji per Jam
          <input id="hourlyRate" type="number" min="0" step="500" placeholder="Contoh: 25000" required aria-required="true">
        </label>
        <button type="submit">Tambah Pekerja</button>
      </form>
    </section>

    <section>
      <div class="toolbar">
        <h2>Daftar Pekerja</h2>
        <div class="toolbar-actions">
          <button class="secondary" type="button" id="toggleWorkersBtn">Sembunyikan</button>
          <button class="secondary" type="button" id="exportBtn" title="Ekspor data" aria-label="Ekspor data">Ekspor</button>
          <button class="secondary" type="button" id="importBtn" title="Impor data" aria-label="Impor data">Impor</button>
          <button class="secondary" type="button" id="clearAllBtn">Bersihkan Semua Data</button>
        </div>
      </div>
      <div id="workersArea" aria-live="polite"></div>
    </section>

    <section class="grid-2">
      <div>
        <h2>Input Absensi</h2>
        <form id="attendanceForm">
          <label>
            Pilih Pekerja
            <select id="attendanceWorker" required aria-required="true"></select>
          </label>
          <label>
            Tanggal
            <input id="attendanceDate" type="date" required aria-required="true">
          </label>
          <label>
            Jam Kerja
            <input id="workHours" type="number" min="0" step="0.5" placeholder="Contoh: 8" required aria-required="true">
          </label>
          <button type="submit">Simpan Absensi</button>
        </form>

        <div class="mass-card">
          <div class="toolbar">
            <h2>Absensi Massal</h2>
            <button class="secondary" type="button" id="toggleMassWorkersBtn">Sembunyikan</button>
          </div>
          <form id="massAttendanceForm" class="mass-form">
            <label>
              Tanggal Absensi
              <input id="massAttendanceDate" type="date" required aria-required="true">
            </label>
            <label>
              Jam Kerja Semua
              <input id="massWorkHours" type="number" min="0" step="0.5" placeholder="Contoh: 8" required aria-required="true">
            </label>
            <button type="submit">Simpan Absensi Massal</button>
          </form>
          <div class="mass-actions">
            <button class="secondary" type="button" id="selectAllMassBtn">Pilih Semua</button>
            <button class="secondary" type="button" id="clearMassBtn">Kosongkan Pilihan</button>
          </div>
          <div id="massWorkersArea" class="mass-list" aria-live="polite"></div>
        </div>
      </div>

      <div>
        <h2>Slip Gaji Pekerja</h2>
        <form id="slipForm">
          <div class="slip-picker">
            <button class="secondary" type="button" id="toggleSlipPickerBtn">Pilih Pekerja</button>
            <label id="slipWorkerField" class="is-hidden">
              Nama Pekerja
              <select id="slipWorker" required aria-required="true"></select>
            </label>
          </div>
          <div class="button-group">
            <button type="submit">Lihat Slip Otomatis</button>
            <button class="secondary" type="button" id="downloadSlipBtn">Download PDF</button>
          </div>
        </form>
      </div>
    </section>

    <section>
      <div class="toolbar">
        <h2>Riwayat Absensi</h2>
        <button class="secondary" type="button" id="toggleAttendanceBtn">Sembunyikan</button>
      </div>
      <div id="attendanceArea" aria-live="polite"></div>
    </section>

    <section>
      <h2>Slip Gaji</h2>
      <div id="salarySlipArea" class="empty">Pilih pekerja untuk melihat slip gaji.</div>
    </section>
  </main>

  <!-- Live region for optional messages -->
  <div id="liveMessage" role="status" aria-live="polite" style="position:fixed;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"></div>

  <script>
    // Configuration
    const BASIC_HOURS = 7;
    const OVERTIME_MULTIPLIER = 1.5;
    const rupiah = new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", maximumFractionDigits: 0 });

    // Elements
    const workerForm = document.getElementById("workerForm");
    const attendanceForm = document.getElementById("attendanceForm");
    const massAttendanceForm = document.getElementById("massAttendanceForm");
    const slipForm = document.getElementById("slipForm");
    const workersArea = document.getElementById("workersArea");
    const attendanceArea = document.getElementById("attendanceArea");
    const massWorkersArea = document.getElementById("massWorkersArea");
    const salarySlipArea = document.getElementById("salarySlipArea");
    const attendanceWorker = document.getElementById("attendanceWorker");
    const slipWorker = document.getElementById("slipWorker");
    const clearAllBtn = document.getElementById("clearAllBtn");
    const toggleWorkersBtn = document.getElementById("toggleWorkersBtn");
    const toggleAttendanceBtn = document.getElementById("toggleAttendanceBtn");
    const toggleMassWorkersBtn = document.getElementById("toggleMassWorkersBtn");
    const toggleSlipPickerBtn = document.getElementById("toggleSlipPickerBtn");
    const slipWorkerField = document.getElementById("slipWorkerField");
    const downloadSlipBtn = document.getElementById("downloadSlipBtn");
    const selectAllMassBtn = document.getElementById("selectAllMassBtn");
    const clearMassBtn = document.getElementById("clearMassBtn");
    const themeToggle = document.getElementById("themeToggle");
    const exportBtn = document.getElementById("exportBtn");
    const importBtn = document.getElementById("importBtn");
    const liveMessage = document.getElementById("liveMessage");

    // App state
    let workers = JSON.parse(localStorage.getItem("workers")) || [];
    let attendances = JSON.parse(localStorage.getItem("attendances")) || [];
    let excludedMassWorkers = [];
    let workersVisible = localStorage.getItem("workersVisible") !== "false";
    let attendanceVisible = localStorage.getItem("attendanceVisible") !== "false";
    let massWorkersVisible = localStorage.getItem("massWorkersVisible") !== "false";
    let lastDeleted = null; // for undo

    // Defaults
    document.getElementById("attendanceDate").valueAsDate = new Date();
    document.getElementById("massAttendanceDate").valueAsDate = new Date();

    // Utility: simple HTML escape to prevent injection
    function escapeHTML(str) {
      return String(str)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function setTheme(theme) {
      document.documentElement.dataset.theme = theme;
      localStorage.setItem("theme", theme);
      themeToggle.textContent = theme === "night" ? "Mode Siang" : "Mode Malam";
      themeToggle.setAttribute("aria-pressed", String(theme === "night"));
      announce(`Tema diatur ke ${theme === 'night' ? 'Malem' : 'Siang'}`);
    }

    function createId() {
      if (window.crypto && window.crypto.randomUUID) return window.crypto.randomUUID();
      return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
    }

    function updateWorkersVisibility() {
      workersArea.classList.toggle("is-hidden", !workersVisible);
      toggleWorkersBtn.textContent = workersVisible ? "Sembunyikan" : "Lihat Daftar";
      localStorage.setItem("workersVisible", String(workersVisible));
    }

    function updateAttendanceVisibility() {
      attendanceArea.classList.toggle("is-hidden", !attendanceVisible);
      toggleAttendanceBtn.textContent = attendanceVisible ? "Sembunyikan" : "Lihat Riwayat";
      localStorage.setItem("attendanceVisible", String(attendanceVisible));
    }

    function updateMassWorkersVisibility() {
      massWorkersArea.classList.toggle("is-hidden", !massWorkersVisible);
      toggleMassWorkersBtn.textContent = massWorkersVisible ? "Sembunyikan" : "Lihat Daftar";
      localStorage.setItem("massWorkersVisible", String(massWorkersVisible));
    }

    function saveData() {
      localStorage.setItem("workers", JSON.stringify(workers));
      localStorage.setItem("attendances", JSON.stringify(attendances));
    }

    function calculateSalary(hours, rate) {
      const basicHours = Math.min(hours, BASIC_HOURS);
      const overtimeHours = Math.max(hours - BASIC_HOURS, 0);
      const basicPay = basicHours * rate;
      const overtimePay = overtimeHours * rate * OVERTIME_MULTIPLIER;
      return { basicHours, overtimeHours, basicPay, overtimePay, totalPay: basicPay + overtimePay };
    }

    function workerNameById(id) {
      const worker = workers.find((item) => item.id === id);
      return worker ? worker.name : "Pekerja dihapus";
    }

    function renderWorkerOptions() {
      const options = workers.map((worker) => `<option value="${worker.id}">${escapeHTML(worker.name)}</option>`).join("");
      const emptyOption = '<option value="">Belum ada pekerja</option>';
      attendanceWorker.innerHTML = workers.length ? options : emptyOption;
      slipWorker.innerHTML = workers.length ? options : emptyOption;
    }

    function renderMassWorkers() {
      excludedMassWorkers = excludedMassWorkers.filter((id) => workers.some((w) => w.id === id));
      const availableWorkers = workers.filter((worker) => !excludedMassWorkers.includes(worker.id));

      if (!workers.length) {
        massWorkersArea.innerHTML = '<div class="empty">Tambahkan pekerja terlebih dahulu untuk absensi massal.</div>';
        return;
      }
      if (!availableWorkers.length) {
        massWorkersArea.innerHTML = '<div class="empty">Semua pekerja sedang dikeluarkan dari daftar absensi massal.</div>';
        return;
      }

      massWorkersArea.innerHTML = availableWorkers.map((worker) => `
        <div class="mass-worker">
          <label>
            <input class="mass-worker-check" type="checkbox" value="${worker.id}" checked aria-label="Pilih ${escapeHTML(worker.name)} untuk absensi massal">
            <span>
              ${escapeHTML(worker.name)}
              <small>${escapeHTML(worker.role)} - ${rupiah.format(worker.rate)} / jam</small>
            </span>
          </label>
          <button class="danger" type="button" data-remove-mass="${worker.id}">Hapus dari Daftar</button>
        </div>
      `).join("");
    }

    function renderWorkers() {
      if (!workers.length) {
        workersArea.innerHTML = '<div class="empty">Belum ada pekerja yang ditambahkan.</div>';
        return;
      }

      workersArea.innerHTML = `
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Nama</th>
                <th>Jabatan</th>
                <th>Gaji per Jam</th>
                <th>Total Absensi</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              ${workers.map((worker) => {
                const totalRecords = attendances.filter((item) => item.workerId === worker.id).length;
                return `
                  <tr>
                    <td>${escapeHTML(worker.name)}</td>
                    <td>${escapeHTML(worker.role)}</td>
                    <td>${rupiah.format(worker.rate)}</td>
                    <td>${totalRecords} hari</td>
                    <td>
                      <div class="actions">
                        <button class="danger" type="button" data-delete-worker="${worker.id}">Hapus</button>
                      </div>
                    </td>
                  </tr>
                `;
              }).join("")}
            </tbody>
          </table>
        </div>
      `;
    }

    function renderAttendances() {
      if (!attendances.length) {
        attendanceArea.innerHTML = '<div class="empty">Belum ada riwayat absensi.</div>';
        return;
      }
      const sortedAttendances = [...attendances].sort((a,b) => b.date.localeCompare(a.date));
      attendanceArea.innerHTML = `
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Tanggal</th>
                <th>Nama</th>
                <th>Jam Basic</th>
                <th>Jam Lembur</th>
                <th>Gaji Basic</th>
                <th>Gaji Lembur</th>
                <th>Total</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              ${sortedAttendances.map((item) => {
                const worker = workers.find((w) => w.id === item.workerId);
                const rate = worker ? worker.rate : item.rate;
                const salary = calculateSalary(Number(item.hours), Number(rate));
                return `
                  <tr>
                    <td>${escapeHTML(item.date)}</td>
                    <td>${escapeHTML(workerNameById(item.workerId))}</td>
                    <td>${salary.basicHours} jam</td>
                    <td>${salary.overtimeHours} jam</td>
                    <td>${rupiah.format(salary.basicPay)}</td>
                    <td>${rupiah.format(salary.overtimePay)}</td>
                    <td><strong>${rupiah.format(salary.totalPay)}</strong></td>
                    <td>
                      <button class="danger" type="button" data-delete-attendance="${item.id}">Hapus</button>
                    </td>
                  </tr>
                `;
              }).join("")}
            </tbody>
          </table>
        </div>
      `;
    }

    function showSlip(workerId = slipWorker.value) {
      const worker = workers.find((item) => item.id === workerId);
      if (!worker) {
        salarySlipArea.innerHTML = '<div class="empty">Pekerja belum dipilih atau belum tersedia.</div>';
        return;
      }
      const records = attendances.filter((item) => item.workerId === worker.id).sort((a,b) => a.date.localeCompare(b.date));
      const totals = records.reduce((result, item) => {
        const salary = calculateSalary(Number(item.hours), worker.rate);
        result.totalHours += Number(item.hours);
        result.basicHours += salary.basicHours;
        result.overtimeHours += salary.overtimeHours;
        result.basicPay += salary.basicPay;
        result.overtimePay += salary.overtimePay;
        result.totalPay += salary.totalPay;
        return result;
      }, { totalHours:0, basicHours:0, overtimeHours:0, basicPay:0, overtimePay:0, totalPay:0 });

      salarySlipArea.innerHTML = `
        <div id="printArea">
          <div class="summary">
            <div><span>Pekerja</span><strong>${escapeHTML(worker.name)}</strong></div>
            <div><span>Gaji per Jam</span><strong>${rupiah.format(worker.rate)}</strong></div>
            <div><span>Total Jam Kerja</span><strong>${totals.totalHours} jam</strong></div>
            <div><span>Total Gaji</span><strong>${rupiah.format(totals.totalPay)}</strong></div>
          </div>
          <div class="summary">
            <div><span>Jabatan</span><strong>${escapeHTML(worker.role)}</strong></div>
            <div><span>Hari Masuk</span><strong>${records.length} hari</strong></div>
            <div><span>Jam Basic</span><strong>${totals.basicHours} jam</strong></div>
            <div><span>Jam Lembur</span><strong>${totals.overtimeHours} jam</strong></div>
            <div><span>Gaji Lembur</span><strong>${rupiah.format(totals.overtimePay)}</strong></div>
          </div>
          ${records.length ? `
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Tanggal</th>
                    <th>Jam Kerja</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  ${records.map(r => {
                    const s = calculateSalary(Number(r.hours), worker.rate);
                    return `
                      <tr>
                        <td>${escapeHTML(r.date)}</td>
                        <td>${r.hours} jam</td>
                        <td>${rupiah.format(s.totalPay)}</td>
                      </tr>
                    `;
                  }).join('')}
                </tbody>
              </table>
            </div>
          ` : '<div class="empty">Belum ada absensi untuk pekerja ini.</div>'}
        </div>
      `;
    }

    // Announce to screen readers via live region
    function announce(message) {
      liveMessage.textContent = '';
      setTimeout(() => { liveMessage.textContent = message; }, 50);
    }

    // Actions
    function addWorker(name, role, rate) {
      const worker = { id: createId(), name: name.trim(), role: role.trim(), rate: Number(rate) };
      workers.push(worker);
      saveData();
      renderAll();
      announce('Pekerja ditambahkan');
    }

    function deleteWorkerById(id) {
      const idx = workers.findIndex(w => w.id === id);
      if (idx === -1) return;
      lastDeleted = { type: 'worker', data: workers[idx], relatedAttendances: attendances.filter(a => a.workerId === id) };
      workers.splice(idx,1);
      // Keep attendances but mark worker removed (or optionally remove). Here we keep attendances as-is.
      saveData(); renderAll(); announce('Pekerja dihapus. Tekan Ctrl+Z untuk undo.');
    }

    function deleteAttendanceById(id) {
      const idx = attendances.findIndex(a => a.id === id);
      if (idx === -1) return;
      lastDeleted = { type: 'attendance', data: attendances[idx] };
      attendances.splice(idx,1);
      saveData(); renderAll(); announce('Riwayat absensi dihapus. Tekan Ctrl+Z untuk undo.');
    }

    function removeFromMassList(id) {
      excludedMassWorkers.push(id);
      renderMassWorkers();
      announce('Pekerja dihapus dari daftar massal');
    }

    // Expose removeFromMassList globally for inline handlers if any exist
    window.removeFromMassList = removeFromMassList;

    // Event wiring
    workerForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('workerName').value;
      const role = document.getElementById('workerRole').value;
      const rate = document.getElementById('hourlyRate').value;
      if (!name.trim() || !role.trim() || Number(rate) < 0) { announce('Periksa input pekerja'); return; }
      addWorker(name, role, rate);
      workerForm.reset();
    });

    attendanceForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const workerId = attendanceWorker.value;
      const date = document.getElementById('attendanceDate').value;
      const hours = document.getElementById('workHours').value;
      if (!workerId) { announce('Pilih pekerja terlebih dahulu'); return; }
      if (!date || Number(hours) < 0) { announce('Periksa input absensi'); return; }
      const attendance = { id: createId(), workerId, date, hours: Number(hours) };
      attendances.push(attendance);
      saveData(); renderAll(); announce('Absensi tersimpan');
      attendanceForm.reset();
      document.getElementById('attendanceDate').valueAsDate = new Date();
    });

    massAttendanceForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const date = document.getElementById('massAttendanceDate').value;
      const hours = Number(document.getElementById('massWorkHours').value);
      if (!date || Number(hours) < 0) { announce('Periksa input absensi massal'); return; }
      const checks = Array.from(document.querySelectorAll('.mass-worker-check'));
      const selected = checks.filter(c => c.checked).map(c => c.value);
      if (!selected.length) { announce('Tidak ada pekerja terpilih'); return; }
      selected.forEach(workerId => { attendances.push({ id: createId(), workerId, date, hours }); });
      saveData(); renderAll(); announce('Absensi massal tersimpan');
    });

    slipForm.addEventListener('submit', (e) => {
      e.preventDefault();
      showSlip();
    });

    // Buttons
    toggleWorkersBtn.addEventListener('click', () => { workersVisible = !workersVisible; updateWorkersVisibility(); });
    toggleAttendanceBtn.addEventListener('click', () => { attendanceVisible = !attendanceVisible; updateAttendanceVisibility(); });
    toggleMassWorkersBtn.addEventListener('click', () => { massWorkersVisible = !massWorkersVisible; updateMassWorkersVisibility(); });
    toggleSlipPickerBtn.addEventListener('click', () => { slipWorkerField.classList.toggle('is-hidden'); });

    clearAllBtn.addEventListener('click', () => {
      if (!confirm('Anda yakin ingin menghapus semua data? Tindakan ini tidak dapat dibatalkan.')) return;
      lastDeleted = { type: 'all', data: { workers: [...workers], attendances: [...attendances] } };
      workers = []; attendances = [];
      saveData(); renderAll(); announce('Semua data dihapus. Tekan Ctrl+Z untuk undo.');
    });

    selectAllMassBtn.addEventListener('click', () => { document.querySelectorAll('.mass-worker-check').forEach(c => c.checked = true); announce('Semua pekerja dipilih'); });
    clearMassBtn.addEventListener('click', () => { document.querySelectorAll('.mass-worker-check').forEach(c => c.checked = false); announce('Pilihan massal dikosongkan'); });

    downloadSlipBtn.addEventListener('click', () => {
      // If a slip is showing, open print dialog for the slip content
      const printArea = document.getElementById('printArea');
      if (!printArea) { announce('Tidak ada slip untuk dicetak. Pilih pekerja dan lihat slip terlebih dahulu.'); return; }
      window.print();
    });

    themeToggle.addEventListener('click', () => { const next = document.documentElement.dataset.theme === 'night' ? 'day' : 'night'; setTheme(next); });

    // Export / Import
    exportBtn.addEventListener('click', () => {
      const payload = { workers, attendances };
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a'); a.href = url; a.download = 'absensi-export.json'; document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
      announce('Data diekspor');
    });

    importBtn.addEventListener('click', () => {
      const input = document.createElement('input'); input.type = 'file'; input.accept = 'application/json';
      input.addEventListener('change', () => {
        const file = input.files[0]; if (!file) return; const reader = new FileReader();
        reader.onload = () => {
          try {
            const data = JSON.parse(reader.result);
            if (Array.isArray(data.workers) && Array.isArray(data.attendances)) {
              workers = data.workers; attendances = data.attendances; saveData(); renderAll(); announce('Data berhasil diimpor');
            } else alert('Format file tidak dikenali');
          } catch (err) { alert('Gagal membaca file: ' + err.message); }
        };
        reader.readAsText(file);
      });
      input.click();
    });

    // Delegated handlers for dynamic buttons
    document.addEventListener('click', (e) => {
      const del = e.target.closest('[data-delete-worker]');
      if (del) {
        const id = del.getAttribute('data-delete-worker');
        if (confirm('Hapus pekerja ini?')) deleteWorkerById(id);
      }
      const delAtt = e.target.closest('[data-delete-attendance]');
      if (delAtt) {
        const id = delAtt.getAttribute('data-delete-attendance');
        if (confirm('Hapus riwayat absensi ini?')) deleteAttendanceById(id);
      }
      const rmMass = e.target.closest('[data-remove-mass]');
      if (rmMass) {
        const id = rmMass.getAttribute('data-remove-mass');
        removeFromMassList(id);
      }
    });

    // Keyboard undo (Ctrl+Z)
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z') {
        if (!lastDeleted) { announce('Tidak ada tindakan untuk dibatalkan'); return; }
        if (lastDeleted.type === 'worker') {
          workers.push(lastDeleted.data);
          // restore related attendances
          attendances = attendances.concat(lastDeleted.relatedAttendances || []);
          saveData(); renderAll(); announce('Penghapusan pekerja dibatalkan'); lastDeleted = null;
        } else if (lastDeleted.type === 'attendance') {
          attendances.push(lastDeleted.data); saveData(); renderAll(); announce('Penghapusan absensi dibatalkan'); lastDeleted = null;
        } else if (lastDeleted.type === 'all') {
          workers = lastDeleted.data.workers; attendances = lastDeleted.data.attendances; saveData(); renderAll(); announce('Semua data dikembalikan'); lastDeleted = null;
        }
      }
    });

    // Persistence & render
    function renderAll() {
      renderWorkerOptions(); renderWorkers(); renderAttendances(); renderMassWorkers(); updateWorkersVisibility(); updateAttendanceVisibility(); updateMassWorkersVisibility();
      // Keep slip select in sync
      renderSlipSelection();
    }

    function renderSlipSelection() {
      // Keep slipWorker options selected if possible
      // If no worker selected, choose first
      if (!workers.length) {
        slipWorkerField.classList.add('is-hidden');
      }
    }

    // Initial setup
    (function init() {
      // Set theme button text
      const theme = document.documentElement.dataset.theme || 'day';
      themeToggle.textContent = theme === 'night' ? 'Mode Siang' : 'Mode Malam';
      themeToggle.setAttribute('aria-pressed', String(theme === 'night'));

      renderAll();
      // Accessibility: focus states and instructions
      announce('Aplikasi absensi siap');
    })();

  </script>
</body>
</html>
